# Google OAuth Web client ID (public — safe to ship in the static bundle).
# Create one: console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID → Web application. Enable the Google Drive API on the project.
# Authorized JavaScript origins: http://localhost:5173 and https://<you>.github.io
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
